{
    "display_information": {
        "name": "Astra",
        "description": "The map of what nobody wrote down — ask about risk, onboarding, or anything in your repos.",
        "background_color": "#0b0905"
    },
    "features": {
        "bot_user": {
            "display_name": "Astra",
            "always_online": true
        }
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "app_mentions:read",
                "chat:write",
                "im:history",
                "im:read",
                "im:write"
            ]
        }
    },
    "settings": {
        "event_subscriptions": {
            "bot_events": [
                "app_mention",
                "message.im"
            ]
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": true,
        "token_rotation_enabled": false
    }
}
