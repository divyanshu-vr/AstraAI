# Copy to .env and fill in. Astra reads .env from this directory.
GROQ_API_KEY=your_groq_key_here

# Embeddings run LOCALLY by default (FastEmbed ONNX, GPU if available) — no key needed.
# Gemini embeddings are optional (free tier caps: 100 contents/min, 1000/day — too small to ingest real repos):
# EMBED_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_key_here

# Optional overrides (sensible defaults in config.py)
# CHROMA_DIR=./.chroma
# LLM_MODEL=llama-3.3-70b-versatile
# EMBED_MODEL=BAAI/bge-small-en-v1.5
# EMBED_DIM=384
# EMBED_GPU=1
# ASTRA_HOST=0.0.0.0
# ASTRA_PORT=7700
